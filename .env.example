# CommandBridge Environment Variables
# Copy this file to backend/.env and frontend/.env.local

# =============================================================================
# BACKEND (.env in backend/)
# =============================================================================

# Server
NODE_ENV=development
PORT=3001

# Database (Neon PostgreSQL)
# Get from: https://console.neon.tech → Connection Details → Connection string
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/commandbridge?sslmode=require

# Authentication (generate a random 32+ char string)
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long
JWT_EXPIRES_IN=7d

# Discord Application (from https://discord.com/developers/applications)
DISCORD_PUBLIC_KEY=your_discord_application_public_key_hex
DISCORD_APPLICATION_ID=your_discord_application_id
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Mirror Webhook (optional - Slack or Discord webhook URL)
MIRROR_WEBHOOK_URL=
MIRROR_WEBHOOK_TYPE=discord

# AI Provider (optional - for auto-tagging/summarization)
AI_PROVIDER=none
GROQ_API_KEY=
GEMINI_API_KEY=

# Initial admin account (used by seed script)
ADMIN_EMAIL=admin@commandbridge.local
ADMIN_PASSWORD=changeme123

# =============================================================================
# FRONTEND (.env.local in frontend/)
# =============================================================================

# API URL (use /api for local dev with Vite proxy, or full URL for production)
VITE_API_URL=/api

# Production example:
# VITE_API_URL=https://commandbridge-api.onrender.com/api
